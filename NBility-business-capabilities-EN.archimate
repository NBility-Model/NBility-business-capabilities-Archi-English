  <folder name="Implementation &amp; Migration" id="id-dfa4f614ea96442ba0a3ac31c2c2d50c" type="implementation_migration"/>
  <folder name="Other" id="id-808016bf07884fbca4dee91fcb878344" type="other">
    <element xsi:type="archimate:Grouping" name="E. Enterprise Capabilities" id="id-172e726793ce49f89ee709a3b9b04c50"/>
  </folder>
